# Data volumes from Docker Compose
gitea-data/
jenkins-data/
registry-data/

# Certificates and keys - generated by generate-certs.sh, never commit
certs/
*.pem
*.crt
*.key
*.p12
*.pfx

# Cosign private key - store in Jenkins credentials only, never commit
cosign.key

# Kubernetes configs - generated by 04-configure-kubernetes.sh, never commit
kubeconfig.yaml
kubeconfig-*.yaml
kubeconfig-jenkins.yaml

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Environment files
.env
.env.*

# System files
.DS_Store
Thumbs.db

# Python cache
__pycache__/

# Backup / scratch files
*.bakk
*.bak
