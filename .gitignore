# Data volumes from Docker Compose
gitea-data/
jenkins-data/
registry-data/

# Certificates and keys - generated by generate-certs.sh, never commit
certs/
*.pem
*.crt
*.key
*.p12
*.pfx

# Cosign private key - store in Jenkins credentials only, never commit
cosign.key

# Kubernetes configs - generated by 04-configure-kubernetes.sh, never commit
kubeconfig.yaml
kubeconfig-*.yaml
kubeconfig-jenkins.yaml

# Environment files
.env
.env.*

# System files
.DS_Store
Thumbs.db

# Python cache
__pycache__/

# Backup / scratch files
*.bakk
*.bak

# sample-flask-app — lives in its own sibling repo.
# 04-configure-kubernetes.sh resolves it at runtime; no symlink or clone
# should ever be committed inside this repo.
sample-flask-app/
sample-flask-app
