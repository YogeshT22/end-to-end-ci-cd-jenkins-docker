FROM jenkins/jenkins:lts-jdk17

USER root

# Basic tools
RUN apt-get update && apt-get install -y \
  git curl sudo wget apt-transport-https \
  ca-certificates gnupg lsb-release gpg tar gzip \
  && apt-get clean && rm -rf /var/lib/apt/lists/*

# Trust the mkcert Root CA - baked into the image at build time
COPY certs/rootCA.crt /usr/local/share/ca-certificates/mkcert-root-ca.crt
RUN chmod 644 /usr/local/share/ca-certificates/mkcert-root-ca.crt && \
  update-ca-certificates

# Install cosign v2.4.1 (pinned version)
RUN wget -q https://github.com/sigstore/cosign/releases/download/v2.4.1/cosign-linux-amd64 \
  -O /usr/local/bin/cosign && chmod +x /usr/local/bin/cosign

# Install Docker CLI (no daemon - uses socket from host)
RUN curl -fsSL https://get.docker.com | sh

# Install kubectl (pinned version)
RUN curl -LO https://dl.k8s.io/release/v1.30.6/bin/linux/amd64/kubectl && \
  install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl && \
  rm kubectl

# Install Trivy v0.69.3 via direct GitHub release download (pinned, verified)
# Using direct download because the apt repo only carries the latest version
ARG TRIVY_VERSION=0.69.3
RUN curl -L "https://github.com/aquasecurity/trivy/releases/download/v${TRIVY_VERSION}/trivy_${TRIVY_VERSION}_Linux-64bit.tar.gz" \
  -o /tmp/trivy.tar.gz && \
  tar -xzf /tmp/trivy.tar.gz -C /tmp trivy && \
  install -o root -g root -m 0755 /tmp/trivy /usr/local/bin/trivy && \
  rm -f /tmp/trivy /tmp/trivy.tar.gz && \
  trivy --version

# Add jenkins user to the docker group so it can use the Docker socket without root/privileged.
# The docker group (GID 999) is created by the get.docker.com installer above;
# no groupmod needed — we just add jenkins to the existing group.
RUN usermod -aG docker jenkins

# Runtime entrypoint: re-GIDs the docker group to match the host socket GID.
# This is required because the host /var/run/docker.sock GID is not known at
# build time and differs per machine.
# Allow the entrypoint to call groupmod without a password via sudo.
COPY jenkins/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh && \
  echo "jenkins ALL=(root) NOPASSWD: /usr/sbin/groupmod" >> /etc/sudoers.d/jenkins-docker && \
  chmod 0440 /etc/sudoers.d/jenkins-docker

# Switch back to jenkins user - container runs as non-root
USER jenkins

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
